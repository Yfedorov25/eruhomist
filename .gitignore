# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Monorepo: patterns are NOT root-anchored so they match inside apps/*/ too.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js / build output
.next/
out/
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (secrets) — keep the example template
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# original hero source archive (kept local, too large for git)
eruhomist-hero-package.zip
_hero_unpacked/
scaffold-tmp/

# playwright-mcp / gstack working artifacts
.playwright-mcp/
hero-verify.png
.gstack/
