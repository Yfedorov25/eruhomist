# nahirna-local ignores (root .gitignore already covers node_modules/.next/.env*)
.npm-cache/
.review-shots/
dev.log
prod.log
*.tsbuildinfo
.vercel
# Orchestrator asset ZIP staging (served copies live in public/)
nahirna-assets/
/video/
/images/night/
/images/landscape/
/images/renders-source/
/landscape/
/*.jpg
# living media: deploy only the optimized web/ subdir; big sources + prototypes stay local
/prototypes/
# raw source renders from the developer (~120MB) — optimized copies live in public/images/gallery/
/newimages/
/public/video/living/*.mp4
/public/video/living/*.webm
/public/video/living/*-poster.jpg
.gstack/
