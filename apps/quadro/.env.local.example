# QUADRO HOUSE — lead form (S7) sends to Telegram via a server action.
# These live ONLY on the server, never shipped to the browser.
# Set them in Vercel project settings too — env vars are per-project, NOT inherited
# from the sibling eruhomist project.
#
# Without these the form does NOT fake success: it returns an honest error and the
# UI shows the fallback contact (phone / Telegram). See app/[locale]/actions/sendLead.ts.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
